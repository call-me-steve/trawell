    "@fastify/rate-limit": "^10.0.2",
    "@trawell/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.3",
    "pino": "^9.6.0",
    "zod": "^3.25.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
